<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CookMate AI</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>

        body{
            background:#FFF8F0;
            font-family:Arial, Helvetica, sans-serif;
        }

        .hero{
            background:linear-gradient(135deg,#ff914d,#ffb347);
            color:white;
            padding:70px 20px;
            text-align:center;
        }

        .hero h1{
            font-size:50px;
            font-weight:bold;
        }

        .hero p{
            font-size:20px;
            margin-top:15px;
        }

        .recipe-card{
            background:white;
            border-radius:20px;
            box-shadow:0 10px 25px rgba(0,0,0,.15);
            padding:35px;
            margin-top:-45px;
        }

        .form-control{
            height:50px;
            border-radius:12px;
        }

        .btn-generate{
            background:#ff6b00;
            color:white;
            width:100%;
            height:50px;
            border:none;
            border-radius:12px;
            font-size:18px;
            font-weight:bold;
        }

        .btn-generate:hover{
            background:#e65c00;
        }

        .result-card{
            display:none;
            margin-top:40px;
            background:white;
            border-radius:20px;
            padding:30px;
            box-shadow:0 10px 25px rgba(0,0,0,.15);
        }

        .loading{
            display:none;
            text-align:center;
            margin-top:30px;
        }

        .download-btn{
            display:none;
        }

        h4{
            color:#ff6b00;
            margin-top:25px;
        }

        ul li{
            margin-bottom:8px;
        }

        ol li{
            margin-bottom:10px;
        }

        footer{
            margin-top:70px;
            text-align:center;
            padding:20px;
            color:gray;
        }

    </style>
</head>
<body>

<!-- Hero -->

<div class="hero">

    <h1><i class="bi bi-robot"></i> CookMate AI</h1>

    <p>Generate Recipes for Any Dish using AI</p>

</div>

<div class="container">

<div class="recipe-card">

<h3 class="text-center mb-4">Recipe Generator</h3>

<form id="recipeForm">

<div class="mb-3">

<label class="form-label">Dish Name</label>

<input
type="text"
class="form-control"
id="dish"
placeholder="Example : Chicken Biryani"
required>

</div>

<div class="mb-4">

<label class="form-label">Number of Servings</label>

<input
type="number"
class="form-control"
id="people"
placeholder="Example : 4"
required>

</div>

<button class="btn btn-generate">
<i class="bi bi-stars"></i>
Generate Recipe
</button>

</form>

<div class="loading" id="loading">

<div class="spinner-border text-warning"></div>

<p class="mt-3">
Generating your recipe...
</p>

</div>

<!-- Result -->

<div class="result-card" id="resultCard">

<h2 id="recipeTitle">
Recipe Name
</h2>

<hr>

<h4>Ingredients</h4>

<div id="ingredients">

Ingredients appear here...

</div>

<h4>Preparation Time</h4>

<p id="prepTime"></p>

<h4>Cooking Time</h4>

<p id="cookTime"></p>

<h4>Difficulty</h4>

<p id="difficulty"></p>

<h4>Cooking Steps</h4>

<div id="steps">

Steps appear here...

</div>

<h4>Chef Tips</h4>

<p id="tips"></p>

<div class="text-center mt-4">

<button
class="btn btn-success download-btn"
id="downloadBtn">

<i class="bi bi-file-earmark-pdf-fill"></i>

Download as PDF

</button>

</div>

</div>

</div>

</div>

<footer>

Made with ❤️ using Flask + Groq AI

</footer>

<script>

document.getElementById("recipeForm").addEventListener("submit",function(e){

e.preventDefault();

document.getElementById("loading").style.display="block";

setTimeout(function(){

document.getElementById("loading").style.display="none";

document.getElementById("resultCard").style.display="block";

document.getElementById("downloadBtn").style.display="inline-block";

},2000);

});

</script>

</body>
</html>
